      <aliases enabled='yes' />
      <column caption='Approval rates (copy)' datatype='string' datatype-customized='true' name='[Approval rates (copy)_0693570167623680]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(SUM(IF [loan_status] = &apos;Approved&apos; THEN 1 ELSE 0 END))' />
      </column>
      <column caption='approval rates' datatype='real' name='[Calculation_0693570172375041]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1239202588094466]/[Calculation_1239202482425856])*100' />
      </column>
      <column caption='nr of applicants' datatype='integer' name='[Calculation_1239202482425856]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([loan_id])' />
      </column>
      <column caption='nr of approved loans' datatype='integer' name='[Calculation_1239202588094466]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [loan_status] = &apos;Approved&apos; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='BAN non_self_employed' datatype='string' name='[Calculation_1239202619506695]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;Non-self-employed Approval Rate: &quot; + STR(ROUND(&#13;&#10;(SUM( IF [self_employed] = &apos;No&apos; AND [loan_status] = &apos;Approved&apos; THEN 1 ELSE 0 END)/&#13;&#10; SUM( IF [self_employed] = &apos;No&apos; THEN 1 ELSE 0 END)) * 100, 2)) + &quot;%&quot;' />
      </column>
      <column caption='BAN self_employed' datatype='string' name='[Calculation_1239202620334089]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;Self-employed Approval Rate: &quot; + STR(ROUND(&#13;&#10;(SUM( IF [self_employed] = &apos;Yes&apos; AND [loan_status] = &apos;Approved&apos; THEN 1 ELSE 0 END)/&#13;&#10; SUM( IF [self_employed] = &apos;Yes&apos; THEN 1 ELSE 0 END)) * 100, 2)) + &quot;%&quot;' />
      </column>
      <column caption='BAN graduate' datatype='string' name='[Calculation_1239202620854282]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;Graduate Approval Rate: &quot; + STR(ROUND(&#13;&#10;(SUM( IF [education] = &apos;Graduate&apos; AND [loan_status] = &apos;Approved&apos; THEN 1 ELSE 0 END)/&#13;&#10; SUM( IF [education] = &apos;Graduate&apos; THEN 1 ELSE 0 END)) * 100, 2)) + &quot;%&quot;' />
      </column>
      <column caption='BAN non-graduate' datatype='string' name='[Calculation_1239202621444107]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;Graduate Approval Rate: &quot; + STR(ROUND(&#13;&#10;(SUM( IF [education] = &apos;Not Graduate&apos; AND [loan_status] = &apos;Approved&apos; THEN 1 ELSE 0 END)/&#13;&#10; SUM( IF [education] = &apos;Not Graduate&apos; THEN 1 ELSE 0 END)) * 100, 2)) + &quot;%&quot;' />
      </column>
      <column aggregation='None' caption='Range of CIBIL scores' datatype='integer' name='[Cibil Score (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='2' formula='[cibil_score]' peg='0' size='100' />
      </column>
      <column aggregation='None' caption='Range of annual income' datatype='integer' name='[Income Annum (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='4' formula='[income_annum]' peg='0' size='1e+06' />
      </column>
